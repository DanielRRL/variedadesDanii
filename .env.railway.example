# =============================================================================
# Variedades DANII — Variables de Entorno para Railway
# =============================================================================
# Las marcadas con * son inyectadas por Railway automáticamente (NO configurar).
# El resto se deben configurar con: railway variables set KEY=VALUE
# =============================================================================

# ── Inyectadas por Railway (*) ───────────────────────────────────────────────
# DATABASE_URL          → Plugin PostgreSQL de Railway

# ── URLs (se obtienen tras el primer deploy) ──────────────────────────────────
API_URL=https://TU-API.up.railway.app
FRONTEND_URL=https://TU-FRONTEND.up.railway.app

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=genera-un-string-aleatorio-de-al-menos-64-caracteres-aqui

# ── Admin seed ───────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=password_seguro_con_numeros_y_simbolos
ADMIN_NAME=Administrador
ADMIN_PHONE=+573001234567

# ── Email SMTP ───────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx        # App Password de Google
EMAIL_FROM=tu_correo@gmail.com
EMAIL_FROM_NAME=Variedades Danni

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxxxxxxxx.apps.googleusercontent.com
