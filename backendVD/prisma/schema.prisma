generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------

enum UserRole {
  ADMIN
  CLIENT
  SELLER
  DELIVERY
}

enum OrderStatus {
  PENDING
  PAID
  PREPARING
  READY
  SHIPPED
  DELIVERED
  CANCELLED
}

enum OrderType {
  ONLINE
  REFILL
  CASH_ON_DELIVERY
}

enum PaymentMethod {
  NEQUI
  DAVIPLATA
  BANCOLOMBIA
  CASH
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
  REFUNDED
}

enum MovementType {
  IN
  OUT
}

enum MovementReason {
  PURCHASE
  SALE
  REFILL
  ADJUSTMENT
  RETURN
}

enum BottleMovementType {
  IN
  OUT
}

enum BottleMovementReason {
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
}

enum BottleType {
  STANDARD
  LUXURY
}

/// DEPRECATED: el sistema de descuentos porcentuales fue reemplazado por el sistema de gramos.
/// Solo se mantiene el descuento por codigo de referido (5%, solo en lociones).
/// Estos enums se conservan por compatibilidad con datos historicos.
enum DiscountType {
  BOTTLE_RETURN
  FREQUENT_CLIENT
  VOLUME
}

// Categoria del producto: perfume artesanal, accesorio u otro producto general.
enum ProductCategory {
  PERFUME
  ACCESSORY
  GENERAL
}

// Tipo de entidad en auditorias de inventario.
enum AuditEntityType {
  ESSENCE
  BOTTLE
  PRODUCT
}

/// Tipo de producto vendible o canjeable en el catalogo.
enum ProductType {
  LOTION          /// Locion perfumada — producto principal de venta. Genera 1 gramo al comprar.
  CREAM           /// Crema corporal o facial. Genera 1 gramo al comprar.
  SHAMPOO         /// Shampoo o acondicionador. Genera 1 gramo al comprar.
  MAKEUP          /// Maquillaje. Genera 1 gramo al comprar.
  SPLASH          /// Body splash. Genera 1 gramo al comprar.
  ACCESSORY       /// Accesorio (sin gramo).
  ESSENCE_CATALOG /// Esencia canjeable — no tiene precio de venta. Solo aparece en pantalla de canje.
}

/// Origen de un movimiento de gramos en la billetera del cliente.
enum GramSourceType {
  PRODUCT_PURCHASE     /// +1g por cada producto de tipo LOTION/CREAM/SHAMPOO/MAKEUP/SPLASH comprado
  ESSENCE_OZ_BONUS     /// +1g al canjear 1 oz o mas de esencia (no aplica a recargas menores a 13g)
  GAME_ROULETTE        /// Gramos ganados jugando ruleta (1-3g)
  GAME_PUZZLE          /// Gramos ganados resolviendo puzzle (1-4g)
  WEEKLY_CHALLENGE     /// Gramos ganados al completar reto semanal
  MONTHLY_RANKING      /// Gramos otorgados al top 10 mensual
  ADMIN_ADJUSTMENT     /// Ajuste manual por administrador
  REDEMPTION           /// Salida de gramos al canjear esencia (valor negativo)
}

/// Estado de una ficha de juego emitida tras una compra confirmada.
enum GameTokenStatus {
  PENDING  /// Ficha emitida, no usada aun
  USED     /// Ficha ya jugada
  EXPIRED  /// Ficha vencida (72h sin usar)
}

/// Tipo de minijuego disponible en la plataforma.
enum GameType {
  ROULETTE /// Ruleta: premio aleatorio 1-3g
  PUZZLE   /// Puzzle de logica: premio 1-4g segun dificultad
}

/// Estado del progreso de un usuario en un reto semanal.
enum ChallengeStatus {
  ACTIVE    /// Reto en curso esta semana
  COMPLETED /// Reto completado por el usuario
  EXPIRED   /// Semana termino sin completar
}

/// Estado de un canje de gramos por esencia.
enum EssenceRedemptionStatus {
  PENDING_DELIVERY /// Gramos descontados, esencia pendiente de entrega fisica por admin
  DELIVERED        /// Admin marco la entrega como completada
  CANCELLED        /// Cancelado por admin (gramos revertidos)
}

// Nivel de fidelizacion del cliente en el programa de puntos.
enum LoyaltyLevel {
  BASIC     // Nivel inicial; sin descuento adicional
  PREFERRED // Nivel intermedio; 5% descuento activo
  VIP       // Nivel alto; 10% descuento activo
  ELITE     // Nivel maximo; 15% descuento y beneficios exclusivos
}

// Tipo de movimiento en el historial de puntos de fidelizacion.
enum LoyaltyTxType {
  EARN   // Acumulacion de puntos por compra o accion
  REDEEM // Canje de puntos como descuento en una orden
  EXPIRE // Expiracion automatica por politica de vencimiento
  ADJUST // Ajuste manual realizado por un administrador
}

// Estado de la factura electronica ante la DIAN (Colombia).
enum InvoiceStatus {
  DRAFT    // Borrador generado localmente, aun no enviado a la DIAN
  SENT     // Enviado a la DIAN, esperando respuesta de aceptacion
  ACCEPTED // Aceptado y validado por la DIAN
  REJECTED // Rechazado por la DIAN; requiere correccion y reenvio
}

// ---------------------------------------------------------------------------
// USERS
// ---------------------------------------------------------------------------

model User {
  id        String   @id @default(uuid())
  name      String
  phone     String   @unique
  email     String   @unique
  password  String
  role      UserRole @default(CLIENT)
  active        Boolean  @default(true)
  /// Indica si el usuario ya verifico su correo electronico (RF-004)
  emailVerified Boolean  @default(false) @map("email_verified")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  orders              Order[]
  bottleReturns       BottleReturn[]
  addresses           Address[]
  inventoryAudits     InventoryAudit[]
  /// Cuenta de puntos de fidelizacion del cliente (1:1)
  loyaltyAccount      LoyaltyAccount?
  /// Codigo de referido propio del cliente (1:1)
  referralCode        ReferralCode?
  /// Registros en los que este usuario uso el codigo de otro cliente
  referralUsages      ReferralUsage[]
  /// Tokens de verificacion de correo emitidos para este usuario
  emailVerifications  EmailVerification[]
  /// Tokens de recuperacion de contrasena emitidos para este usuario
  passwordResets      PasswordReset[]
  /// Cambios de estado de pedido realizados por este usuario (admin/seller)
  orderStatusChanges  OrderStatusHistory[]
  /// Billetera de gramos del cliente (1:1)
  gramAccount         GramAccount?
  /// Fichas de juego emitidas por compras confirmadas
  gameTokens          GameToken[]
  /// Canjes de gramos por esencia realizados
  essenceRedemptions  EssenceRedemption[]
  /// Progreso en retos semanales
  challengeProgresses UserChallengeProgress[]

  @@map("users")
}

model Address {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  city      String
  address   String
  detail    String?
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

// ---------------------------------------------------------------------------
// CATALOG
// ---------------------------------------------------------------------------

model OlfactiveFamily {
  id   String @id @default(uuid())
  name String @unique

  essences Essence[]

  @@map("olfactive_families")
}

model Essence {
  id                String   @id @default(uuid())
  name              String
  description       String?
  olfactiveFamilyId String   @map("olfactive_family_id")
  inspirationBrand  String?  @map("inspiration_brand")
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  olfactiveFamily    OlfactiveFamily     @relation(fields: [olfactiveFamilyId], references: [id])
  products           Product[]
  essenceMovements   EssenceMovement[]

  @@map("essences")
}

model Bottle {
  id        String     @id @default(uuid())
  name      String
  type      BottleType
  material  String
  capacityMl Float     @map("capacity_ml")
  active    Boolean    @default(true)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  products        Product[]
  bottleMovements BottleMovement[]
  bottleReturns   BottleReturn[]

  @@map("bottles")
}

model Product {
  id          String          @id @default(uuid())
  name        String
  description String?
  category    ProductCategory @default(PERFUME)
  essenceId   String?         @map("essence_id")
  bottleId    String?         @map("bottle_id")
  mlQuantity  Float?          @map("ml_quantity")
  price       Float
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  /// Tipo de producto: locion, crema, maquillaje, etc.
  productType    ProductType  @default(LOTION) @map("product_type")
  /// Indica si la compra de este producto genera 1 gramo acumulable. True para LOTION/CREAM/SHAMPOO/MAKEUP/SPLASH.
  generatesGram  Boolean      @default(true) @map("generates_gram")
  /// Stock en unidades para productos vendibles. Las esencias del catalogo (ESSENCE_CATALOG) usan EssenceMovement.
  stockUnits     Int          @default(0) @map("stock_units")
  /// URL de foto del producto. Puede ser diferente a la foto de la esencia vinculada.
  photoUrl       String?      @map("photo_url")

  essence          Essence?          @relation(fields: [essenceId], references: [id])
  bottle           Bottle?           @relation(fields: [bottleId], references: [id])
  orderItems       OrderItem[]
  movements        ProductMovement[]
  /// Relacion con gramos ganados: todos los GramTransaction originados por compras de este producto.
  gramTransactions GramTransaction[]

  @@unique([essenceId, bottleId, mlQuantity])
  @@map("products")
}

// ---------------------------------------------------------------------------
// INVENTORY - Movements-based (not direct stock fields)
// ---------------------------------------------------------------------------

model EssenceMovement {
  id        String          @id @default(uuid())
  essenceId String          @map("essence_id")
  type      MovementType
  ml        Float
  reason    MovementReason
  reference String?
  createdAt DateTime        @default(now()) @map("created_at")

  essence Essence @relation(fields: [essenceId], references: [id])

  @@map("essence_movements")
}

model BottleMovement {
  id        String               @id @default(uuid())
  bottleId  String               @map("bottle_id")
  type      BottleMovementType
  quantity  Int
  reason    BottleMovementReason
  reference String?
  createdAt DateTime             @default(now()) @map("created_at")

  bottle Bottle @relation(fields: [bottleId], references: [id])

  @@map("bottle_movements")
}

// ---------------------------------------------------------------------------
// ORDERS
// ---------------------------------------------------------------------------

model Order {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  addressId     String?       @map("address_id")
  type          OrderType     @default(ONLINE)
  status        OrderStatus   @default(PENDING)
  subtotal      Float
  discount      Float         @default(0)
  total         Float
  paymentMethod PaymentMethod @map("payment_method")
  notes         String?
  /// Numero de pedido legible en formato VD-YYYYXXXX, generado en capa de negocio (RF-025)
  orderNumber   String?       @unique @map("order_number")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user     User        @relation(fields: [userId], references: [id])
  address  Address?    @relation(fields: [addressId], references: [id])
  items         OrderItem[]
  payment       Payment?
  discounts     OrderDiscount[]
  /// Historial de todas las transiciones de estado de esta orden
  statusHistory OrderStatusHistory[]
  /// Factura electronica asociada a esta orden (1:1, opcional)
  invoice       ElectronicInvoice?

  @@map("orders")
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String @map("order_id")
  productId String @map("product_id")
  quantity  Int
  unitPrice Float  @map("unit_price")
  subtotal  Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model OrderDiscount {
  id          String       @id @default(uuid())
  orderId     String       @map("order_id")
  type        DiscountType
  percentage  Float
  amount      Float
  description String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_discounts")
}

// ---------------------------------------------------------------------------
// PAYMENTS
// ---------------------------------------------------------------------------

model Payment {
  id              String        @id @default(uuid())
  orderId         String        @unique @map("order_id")
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  amount          Float
  gatewayRef       String?       @map("gateway_ref")
  gatewayResponse  Json?         @map("gateway_response")
  /// Referencia de transaccion Bre-B/Wompi para rastrear el pago en la pasarela
  brebRef          String?       @map("breb_ref")
  /// Payload JSON completo del webhook recibido de Bre-B, almacenado para auditoria y reproceso
  brebWebhookData  Json?         @map("breb_webhook_data")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

// ---------------------------------------------------------------------------
// BOTTLE RETURNS (refill program)
// ---------------------------------------------------------------------------

model BottleReturn {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  bottleId        String   @map("bottle_id")
  discountApplied Float    @map("discount_applied")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id])
  bottle Bottle @relation(fields: [bottleId], references: [id])

  @@map("bottle_returns")
}

// ---------------------------------------------------------------------------
// PRODUCT MOVEMENTS - Inventario basado en movimientos para productos
// generales (accesorios, productos no-esencia). Los perfumes usan
// EssenceMovement y BottleMovement para su control.
// ---------------------------------------------------------------------------

model ProductMovement {
  id        String         @id @default(uuid())
  productId String         @map("product_id")
  type      MovementType
  quantity  Int
  reason    MovementReason
  reference String?
  createdAt DateTime       @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])

  @@map("product_movements")
}

// ---------------------------------------------------------------------------
// INVENTORY AUDITS - Conciliacion de inventario fisico vs sistema.
// Se registra al hacer conteo fisico para detectar diferencias.
// ---------------------------------------------------------------------------

model InventoryAudit {
  id            String          @id @default(uuid())
  entityType    AuditEntityType @map("entity_type")
  entityId      String          @map("entity_id")
  systemValue   Float           @map("system_value")
  physicalValue Float           @map("physical_value")
  difference    Float
  notes         String?
  userId        String          @map("user_id")
  createdAt     DateTime        @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("inventory_audits")
}

// ---------------------------------------------------------------------------
// LOYALTY PROGRAM - Puntos de fidelizacion y niveles de cliente
// ---------------------------------------------------------------------------

// Cuenta de puntos de fidelizacion asociada 1:1 con un cliente.
model LoyaltyAccount {
  /// Identificador unico (UUID) de la cuenta
  id          String       @id @default(uuid())
  /// FK al usuario dueno de la cuenta; cada usuario tiene una sola cuenta
  userId      String       @unique @map("user_id")
  /// Puntos actuales disponibles para canje
  points      Int          @default(0)
  /// Nivel de fidelizacion calculado segun puntos historicos acumulados
  level       LoyaltyLevel @default(BASIC)
  /// Porcentaje de descuento activo segun el nivel (0.0 a 30.0)
  discountPct Float        @default(0) @map("discount_pct")
  /// Fecha de la ultima modificacion de puntos o nivel (auto-gestionada)
  updatedAt   DateTime     @updatedAt @map("updated_at")

  /// Usuario propietario de esta cuenta de puntos
  user         User                @relation(fields: [userId], references: [id])
  /// Movimientos de puntos (entradas, canjes, expiraciones, ajustes)
  transactions LoyaltyTransaction[]

  @@map("loyalty_accounts")
}

// Registro individual de un movimiento de puntos en una cuenta de fidelizacion.
model LoyaltyTransaction {
  /// Identificador unico (UUID) del movimiento
  id          String        @id @default(uuid())
  /// FK a la cuenta de fidelizacion sobre la que aplica el movimiento
  accountId   String        @map("account_id")
  /// Clasificacion del movimiento: acumulacion, canje, expiracion o ajuste
  type        LoyaltyTxType
  /// Cantidad de puntos afectados; positivo = acumulacion, negativo = canje/expiracion
  points      Int
  /// Descripcion legible del motivo del movimiento (ej. "Compra orden VD-20240001")
  reason      String
  /// ID opcional de la orden o devolucion que origino el movimiento
  referenceId String?       @map("reference_id")
  /// Fecha y hora de creacion del movimiento
  createdAt   DateTime      @default(now()) @map("created_at")

  /// Cuenta de fidelizacion a la que pertenece este movimiento
  account LoyaltyAccount @relation(fields: [accountId], references: [id])

  @@map("loyalty_transactions")
}

// ---------------------------------------------------------------------------
// REFERRAL PROGRAM - Codigos de referido entre clientes
// ---------------------------------------------------------------------------

// Codigo unico de referido asignado a cada cliente para compartir con nuevos usuarios.
model ReferralCode {
  /// Identificador unico (UUID) del codigo
  id         String   @id @default(uuid())
  /// FK al usuario propietario del codigo; cada usuario tiene maximo un codigo
  userId     String   @unique @map("user_id")
  /// Cadena alfanumerica legible que el cliente comparte (ej. MARIA15)
  code       String   @unique
  /// Numero de veces que el codigo ha sido utilizado exitosamente
  usageCount Int      @default(0) @map("usage_count")
  /// Fecha de generacion del codigo
  createdAt  DateTime @default(now()) @map("created_at")

  /// Usuario dueno del codigo
  user   User            @relation(fields: [userId], references: [id])
  /// Registros de uso de este codigo por nuevos clientes
  usages ReferralUsage[]

  @@map("referral_codes")
}

// Registro de cada vez que un nuevo usuario utilizo un codigo de referido.
model ReferralUsage {
  /// Identificador unico (UUID) del uso
  id             String   @id @default(uuid())
  /// FK al codigo de referido que fue utilizado
  referralCodeId String   @map("referral_code_id")
  /// FK al nuevo usuario que ingreso usando el codigo
  newUserId      String   @map("new_user_id")
  /// Indica si ya se proceso y entrego la recompensa al dueno del codigo
  rewardGiven    Boolean  @default(false) @map("reward_given")
  /// Fecha en que se registro el uso del codigo
  createdAt      DateTime @default(now()) @map("created_at")

  /// Codigo de referido que fue utilizado
  referralCode ReferralCode @relation(fields: [referralCodeId], references: [id])
  /// Nuevo usuario que utilizo el codigo
  newUser      User         @relation(fields: [newUserId], references: [id])

  @@map("referral_usages")
}

// ---------------------------------------------------------------------------
// ORDER STATUS HISTORY - Auditoria de cambios de estado de pedidos
// ---------------------------------------------------------------------------

// Registro inmutable de cada transicion de estado de un pedido.
model OrderStatusHistory {
  /// Identificador unico (UUID) del registro
  id          String      @id @default(uuid())
  /// FK al pedido cuyo estado fue modificado
  orderId     String      @map("order_id")
  /// Estado anterior antes de la transicion
  fromStatus  OrderStatus @map("from_status")
  /// Nuevo estado al que paso el pedido
  toStatus    OrderStatus @map("to_status")
  /// FK al usuario (admin/vendedor/domiciliario) que realizo el cambio
  changedById String      @map("changed_by_id")
  /// Notas opcionales que justifican o describen el cambio de estado
  notes       String?
  /// Fecha y hora exacta del cambio de estado
  createdAt   DateTime    @default(now()) @map("created_at")

  /// Pedido al que pertenece este historial de estado
  order     Order @relation(fields: [orderId], references: [id])
  /// Usuario que ejecuto el cambio de estado
  changedBy User  @relation(fields: [changedById], references: [id])

  @@map("order_status_history")
}

// ---------------------------------------------------------------------------
// AUTH TOKENS - Verificacion de correo y recuperacion de contrasena
// ---------------------------------------------------------------------------

// Token de un solo uso para verificar la direccion de correo del usuario (RF-004).
model EmailVerification {
  /// Identificador unico (UUID) del token
  id        String    @id @default(uuid())
  /// FK al usuario que solicito la verificacion de su correo
  userId    String    @map("user_id")
  /// Token aleatorio firmado enviado al correo; debe ser unico en la tabla
  token     String    @unique
  /// Fecha y hora limite para usar el token; pasada esta fecha queda invalido
  expiresAt DateTime  @map("expires_at")
  /// Fecha en que el token fue consumido; null si aun no se ha utilizado
  usedAt    DateTime? @map("used_at")
  /// Fecha de generacion del token
  createdAt DateTime  @default(now()) @map("created_at")

  /// Usuario al que pertenece este token (cascade: si se elimina el usuario, se eliminan sus tokens)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

// Token de un solo uso para autorizar el cambio de contrasena olvidada.
model PasswordReset {
  /// Identificador unico (UUID) del token
  id        String    @id @default(uuid())
  /// FK al usuario que solicito el restablecimiento de su contrasena
  userId    String    @map("user_id")
  /// Token aleatorio enviado al correo para autorizar el cambio; debe ser unico
  token     String    @unique
  /// Fecha y hora limite para usar el token; pasada esta fecha queda invalido
  expiresAt DateTime  @map("expires_at")
  /// Fecha en que el token fue consumido; null si aun no se ha utilizado
  usedAt    DateTime? @map("used_at")
  /// Fecha de generacion del token
  createdAt DateTime  @default(now()) @map("created_at")

  /// Usuario al que pertenece este token (cascade: si se elimina el usuario, se eliminan sus tokens)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

// ---------------------------------------------------------------------------
// ELECTRONIC INVOICES - Facturacion electronica DIAN (Colombia)
// ---------------------------------------------------------------------------

// Factura electronica conforme a la normativa DIAN asociada a un pedido.
model ElectronicInvoice {
  /// Identificador unico (UUID) de la factura
  id            String        @id @default(uuid())
  /// FK al pedido facturado; relacion 1:1 (un pedido tiene una sola factura)
  orderId       String        @unique @map("order_id")
  /// Numero de factura secuencial en formato SEQF-0001, generado en capa de negocio
  invoiceNumber String        @unique @map("invoice_number")
  /// Codigo Unico de Factura Electronica asignado por la DIAN tras aceptacion
  cufe          String?
  /// Estado actual del ciclo de vida de la factura ante la DIAN
  status        InvoiceStatus @default(DRAFT)
  /// Contenido XML de la factura en formato UBL 2.1 requerido por la DIAN
  xmlContent    String?       @map("xml_content")
  /// URL publica del PDF generado para entregar al cliente
  pdfUrl        String?       @map("pdf_url")
  /// Respuesta JSON completa devuelta por la DIAN o el proveedor tecnologico habilitado
  dianResponse  Json?         @map("dian_response")
  /// Fecha y hora en que la factura fue emitida y enviada a la DIAN
  issuedAt      DateTime?     @map("issued_at")
  /// Fecha de creacion del registro en el sistema
  createdAt     DateTime      @default(now()) @map("created_at")

  /// Pedido al que pertenece esta factura electronica
  order Order @relation(fields: [orderId], references: [id])

  @@map("electronic_invoices")
}

// ---------------------------------------------------------------------------
// GAMIFICATION & GRAM SYSTEM - Sistema de gramos y juegos
// ---------------------------------------------------------------------------

/// Billetera de gramos del cliente. Maximo 13g simultaneos (1 oz = 13g).
/// Al llegar a 13g el sistema emite automaticamente un EssenceRedemption disponible.
model GramAccount {
  id              String   @id @default(uuid())
  /// FK al usuario dueno de la billetera; cada usuario tiene una sola billetera de gramos
  userId          String   @unique @map("user_id")
  /// Gramos actuales disponibles para canjear (0 a 13, nunca mas de 13).
  currentGrams    Int      @default(0) @map("current_grams")
  /// Total historico de gramos ganados (nunca decrece).
  totalEarned     Int      @default(0) @map("total_earned")
  /// Total historico de gramos canjeados (nunca decrece).
  totalRedeemed   Int      @default(0) @map("total_redeemed")
  /// Total de compras entregadas del usuario. Habilita el canje cuando llega a 5.
  totalPurchases  Int      @default(0) @map("total_purchases")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user         User              @relation(fields: [userId], references: [id])
  transactions GramTransaction[]

  @@map("gram_accounts")
}

/// Log inmutable de cada movimiento de gramos. Nunca se elimina ni edita.
model GramTransaction {
  id          String         @id @default(uuid())
  /// FK a la billetera de gramos sobre la que aplica el movimiento
  accountId   String         @map("account_id")
  /// Origen del movimiento: compra, juego, reto, ajuste admin o canje
  sourceType  GramSourceType @map("source_type")
  /// Positivo = ganancia, negativo = canje/descuento.
  gramsDelta  Int            @map("grams_delta")
  /// Descripcion legible del movimiento para mostrar en el historial.
  description String
  /// ID del pedido, ficha de juego, reto o ajuste que origino el movimiento.
  referenceId String?        @map("reference_id")
  createdAt   DateTime       @default(now()) @map("created_at")

  account     GramAccount @relation(fields: [accountId], references: [id])
  product     Product?    @relation(fields: [referenceId], references: [id])

  @@map("gram_transactions")
}

/// Ficha de juego emitida por cada compra confirmada.
/// Maximo 3 fichas PENDING por usuario. Vence en 72 horas.
model GameToken {
  id          String          @id @default(uuid())
  /// FK al usuario que recibio la ficha
  userId      String          @map("user_id")
  /// ID del pedido que origino esta ficha.
  orderId     String          @map("order_id")
  /// Estado de la ficha: PENDING, USED o EXPIRED
  status      GameTokenStatus @default(PENDING)
  /// Tipo de juego elegido por el usuario al jugar. Null mientras status=PENDING.
  gameType    GameType?       @map("game_type")
  /// Gramos ganados en la partida. 0 mientras no se juega.
  gramsWon    Int             @default(0) @map("grams_won")
  /// Fecha limite para usar la ficha (72h desde creacion).
  expiresAt   DateTime        @map("expires_at")
  /// Fecha en que el usuario jugo. Null si aun no se ha jugado.
  playedAt    DateTime?       @map("played_at")
  createdAt   DateTime        @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("game_tokens")
}

/// Registro de cada canje de gramos por esencia.
/// Se crea automaticamente cuando currentGrams llega a 13 (1 oz completa).
/// Tambien se puede crear manualmente por canje parcial.
model EssenceRedemption {
  id            String                   @id @default(uuid())
  /// FK al usuario que realizo el canje
  userId        String                   @map("user_id")
  /// Gramos descontados de la billetera del cliente.
  gramsUsed     Int                      @map("grams_used")
  /// Onzas equivalentes: gramsUsed / 13.0 (puede ser fraccion).
  ozRedeemed    Float                    @map("oz_redeemed")
  /// Nombre de la esencia elegida por el cliente al canjear.
  essenceName   String                   @map("essence_name")
  /// ID de la esencia del catalogo elegida.
  essenceId     String?                  @map("essence_id")
  /// Estado del canje: pendiente de entrega, entregado o cancelado
  status        EssenceRedemptionStatus  @default(PENDING_DELIVERY)
  /// Notas del admin al entregar (ej: "entregado en tienda el 15/3").
  adminNotes    String?                  @map("admin_notes")
  /// Admin que proceso la entrega.
  deliveredById String?                  @map("delivered_by_id")
  deliveredAt   DateTime?                @map("delivered_at")
  createdAt     DateTime                 @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("essence_redemptions")
}

/// Reto semanal creado por el admin. Visible para todos los clientes.
model WeeklyChallenge {
  id                  String   @id @default(uuid())
  /// Descripcion del reto que ve el cliente (ej: "Compra 3 lociones esta semana").
  description         String
  /// Gramos de premio al completar el reto.
  gramReward          Int      @map("gram_reward")
  /// Numero de compras necesarias para completar el reto.
  requiredPurchases   Int      @map("required_purchases")
  /// Inicio del periodo semanal del reto
  weekStart           DateTime @map("week_start")
  /// Fin del periodo semanal del reto
  weekEnd             DateTime @map("week_end")
  /// Si el reto esta activo y visible para los clientes.
  active              Boolean  @default(true)
  createdAt           DateTime @default(now()) @map("created_at")

  progresses UserChallengeProgress[]

  @@map("weekly_challenges")
}

/// Progreso individual de un usuario en un reto semanal.
model UserChallengeProgress {
  id              String          @id @default(uuid())
  /// FK al usuario participante
  userId          String          @map("user_id")
  /// FK al reto semanal
  challengeId     String          @map("challenge_id")
  /// Compras realizadas durante el periodo del reto.
  purchasesCount  Int             @default(0) @map("purchases_count")
  /// Si ya completo el reto y recibio el premio.
  completed       Boolean         @default(false)
  /// Fecha en que completo el reto. Null si no lo ha completado.
  completedAt     DateTime?       @map("completed_at")
  createdAt       DateTime        @default(now()) @map("created_at")

  user      User            @relation(fields: [userId], references: [id])
  challenge WeeklyChallenge @relation(fields: [challengeId], references: [id])

  @@unique([userId, challengeId])
  @@map("user_challenge_progresses")
}
