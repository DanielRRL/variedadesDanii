<!DOCTYPE html>
<!--
  Template: verification.hbs
  Proposito: Correo de activacion de cuenta para nuevos usuarios.
  Variables Handlebars:
    - {{name}}            : Nombre del usuario.
    - {{verificationUrl}} : URL completa con el token de verificacion.
  Notas:
    - CSS completamente inline para maxima compatibilidad (Gmail, Outlook, iOS Mail).
    - Diseño de una columna centrada, max-width 600px.
    - El token expira en 24 horas; el usuario debe hacer clic antes de ese plazo.
-->
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Activa tu cuenta – Variedades DANII</title>
</head>
<body style="margin:0;padding:0;background-color:#f5f5f5;font-family:Arial,Helvetica,sans-serif;">

  <!-- Contenedor externo centrado -->
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
         style="background-color:#f5f5f5;padding:32px 16px;">
    <tr>
      <td align="center">

        <!-- Tarjeta principal (max-width 600px) -->
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
               style="max-width:600px;background-color:#ffffff;border-radius:8px;
                      overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.08);">

          <!-- ===== ENCABEZADO ROSA ===== -->
          <tr>
            <td style="background-color:#D81B60;padding:28px 32px;text-align:center;">
              <h1 style="margin:0;color:#ffffff;font-size:24px;font-weight:700;
                         letter-spacing:1px;">Variedades DANII</h1>
              <p style="margin:6px 0 0;color:#fce4ec;font-size:13px;">
                Perfumeria artesanal &bull; Armenia, Quindio
              </p>
            </td>
          </tr>

          <!-- ===== CUERPO ===== -->
          <tr>
            <td style="padding:36px 32px;">

              <!-- Saludo personalizado -->
              <p style="margin:0 0 16px;font-size:16px;color:#212121;">
                Hola <strong>{{name}}</strong>,
              </p>

              <!-- Mensaje principal -->
              <p style="margin:0 0 16px;font-size:15px;color:#424242;line-height:1.6;">
                Gracias por registrarte en <strong>Variedades DANII</strong>.
                Para completar tu registro y activar tu cuenta, haz clic en el
                boton a continuacion:
              </p>

              <!-- Boton de verificacion -->
              <table role="presentation" cellpadding="0" cellspacing="0"
                     style="margin:28px auto;">
                <tr>
                  <td style="background-color:#D81B60;border-radius:6px;
                             text-align:center;">
                    <a href="{{verificationUrl}}"
                       style="display:inline-block;padding:14px 32px;
                              color:#ffffff;font-size:15px;font-weight:700;
                              text-decoration:none;border-radius:6px;">
                      Activar mi cuenta
                    </a>
                  </td>
                </tr>
              </table>

              <!-- Nota de expiracion -->
              <p style="margin:0 0 16px;font-size:13px;color:#757575;line-height:1.6;">
                Este enlace es valido durante <strong>24 horas</strong> a partir
                del momento en que recibiste este correo. Si no solicitaste esta
                verificacion, puedes ignorar este mensaje.
              </p>

              <!-- URL alternativa para clientes que bloquean botones -->
              <p style="margin:0;font-size:12px;color:#9e9e9e;line-height:1.5;
                        word-break:break-all;">
                Si el boton no funciona, copia y pega este enlace en tu navegador:
                <br/>
                <span style="color:#D81B60;">{{verificationUrl}}</span>
              </p>

            </td>
          </tr>

          <!-- ===== PIE DE PAGINA ===== -->
          <tr>
            <td style="background-color:#fce4ec;padding:20px 32px;text-align:center;
                       border-top:1px solid #f8bbd0;">
              <p style="margin:0 0 4px;font-size:12px;color:#880e4f;font-weight:700;">
                Variedades DANII Perfumeria
              </p>
              <p style="margin:0;font-size:11px;color:#ad1457;">
                C.C. San Andresito Calle 18 #15-26, Armenia Quindio
                &bull; 300 383 7442
              </p>
            </td>
          </tr>

        </table>
        <!-- Fin tarjeta -->

      </td>
    </tr>
  </table>

</body>
</html>
