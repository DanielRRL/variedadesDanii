PORT=4000
NODE_ENV=development

DATABASE_URL=postgresql://postgres:password@localhost:5432/variedades_danni?schema=public

JWT_SECRET=cambiar-este-secreto-en-produccion
JWT_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:3000

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─────────────────────────────────────────────────────────────────────────────
# Servicio de correo electronico (Nodemailer + Brevo SMTP relay)
# ─────────────────────────────────────────────────────────────────────────────
# Host del relay SMTP de Brevo.
EMAIL_HOST=smtp-relay.brevo.com

# Puerto STARTTLS (587) — no usar 465 (SSL) con esta configuracion.
EMAIL_PORT=587

# Login de tu cuenta Brevo (el correo con el que te registraste).
EMAIL_USER=tu_correo@ejemplo.com

# Clave SMTP de Brevo que se genera en: Cuenta → SMTP & API → Claves SMTP.
# NO es tu contrasena de acceso a brevo.com.
EMAIL_PASS=tu_clave_smtp_brevo

# Direccion que aparece como remitente en los correos enviados.
EMAIL_FROM=no-reply@variedadesdanii.com

# Nombre visible del remitente en el cliente de correo del destinatario.
EMAIL_FROM_NAME=Variedades DANII Perfumeria

# URL base publica de la API, usada para construir los enlaces de
# verificacion de correo y recuperacion de contrasena.
# En produccion debe ser la URL real del servidor (ej: https://api.variedadesdanii.com).
BASE_URL=http://localhost:4000
