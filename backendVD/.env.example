PORT=4000
NODE_ENV=development

DATABASE_URL=postgresql://postgres:password@localhost:5432/variedades_danni?schema=public

JWT_SECRET=cambiar-este-secreto-en-produccion-genera-con-openssl-rand-base64-48
JWT_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:3000

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─────────────────────────────────────────────────────────────────────────────
# Servicio de correo electronico (Nodemailer + Brevo SMTP relay)
# ─────────────────────────────────────────────────────────────────────────────
# Host del relay SMTP de Brevo.
EMAIL_HOST=smtp-relay.brevo.com

# Puerto STARTTLS (587) — no usar 465 (SSL) con esta configuracion.
EMAIL_PORT=587

# Login de tu cuenta Brevo (el correo con el que te registraste).
EMAIL_USER=contacto@variedadesdanii.com

# Clave SMTP de Brevo que se genera en: Cuenta → SMTP & API → Claves SMTP.
# NO es tu contrasena de acceso a brevo.com.
EMAIL_PASS=tu_clave_smtp_brevo

# Direccion que aparece como remitente en los correos enviados.
EMAIL_FROM=contacto@variedadesdanii.com

# Nombre visible del remitente en el cliente de correo del destinatario.
EMAIL_FROM_NAME=Variedades DANII Perfumeria

# URL base publica de la API, usada para construir los enlaces de
# verificacion de correo y recuperacion de contrasena.
# En produccion debe ser la URL real del servidor (ej: https://api.variedadesdanii.com).
BASE_URL=http://localhost:4000

# ─────────────────────────────────────────────────────────────────────────────
# Wompi - Pasarela de pagos colombiana (https://wompi.co)
# En sandbox usar las claves que Wompi proporciona en el panel de pruebas.
# En produccion sustituir por las claves de produccion (sin "test_" en el nombre).
# ─────────────────────────────────────────────────────────────────────────────
# URL base de la API Wompi. Cambiar a https://production.wompi.co/v1 en produccion.
WOMPI_API_URL=https://sandbox.wompi.co/v1

# Clave publica de Wompi (se expone al frontend para iniciar el widget de pago).
WOMPI_PUBLIC_KEY=pub_test_XXXXXXXXXXXXXXXXXXXXXXXX

# Clave privada de Wompi (NUNCA exponer al frontend; solo usarla en el servidor).
WOMPI_PRIVATE_KEY=prv_test_XXXXXXXXXXXXXXXXXXXXXXXX

# Secreto de eventos Wompi (para validar la firma HMAC-SHA256 de los webhooks).
# Se obtiene en: Panel Wompi -> Desarrolladores -> Eventos -> Secreto de eventos.
WOMPI_EVENTS_SECRET=test_events_XXXXXXXXXXXXXXXXXXXXXXXX

# Moneda de las transacciones (solo COP esta habilitada en Colombia).
WOMPI_CURRENCY=COP

# URL a la que Wompi redirige al cliente despues de completar el pago.
# Debe ser una URL publica accesible por el navegador del cliente.
WOMPI_REDIRECT_URL=http://localhost:5173/payment-result

# ─────────────────────────────────────────────────────────────────────────────
# DIAN - Facturacion Electronica Colombia
# Ver docs/DIAN_INTEGRATION.md para el proceso completo de habilitacion.
# Mientras el STUB este activo, estos valores NO son requeridos en desarrollo.
# ─────────────────────────────────────────────────────────────────────────────
# Ambiente DIAN: "test" = habilitador (pruebas), "production" = produccion.
DIAN_ENV=test

# URL del servicio SOAP de la DIAN segun el ambiente.
# test:       https://vpfe-hab.dian.gov.co/WcfDianCustomerServices.svc
# production: https://vpfe.dian.gov.co/WcfDianCustomerServices.svc
DIAN_API_URL=https://vpfe-hab.dian.gov.co/WcfDianCustomerServices.svc

# NIT del emisor (sin digito de verificacion).
DIAN_NIT=900000000

# Digito de verificacion del NIT.
DIAN_NIT_CHECK_DIGIT=0

# Razon social del negocio tal como aparece ante la DIAN.
DIAN_COMPANY_NAME=Variedades Danni

# Correo electronico de facturacion del emisor.
DIAN_EMAIL=facturas@variedadesdanni.co

# Telefono del emisor (con indicativo, ej: +573001234567).
DIAN_PHONE=+573001234567

# Direccion fisica del emisor.
DIAN_ADDRESS=Carrera 14 # 12-34 Local 5

# Codigo DANE del municipio (Armenia, Quindio = 63001).
DIAN_CITY_CODE=63001

# Nombre del municipio del emisor.
DIAN_CITY_NAME=Armenia

# Codigo DANE del departamento (Quindio = 63).
DIAN_DEPARTMENT_CODE=63

# Nombre del departamento del emisor.
DIAN_DEPARTMENT_NAME=Quindio

# Regimen tributario del emisor. "48" = No responsable de IVA.
DIAN_TAX_REGIME=48

# ID del software obtenido al registrar el software en el portal Muisca de la DIAN.
DIAN_SOFTWARE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# PIN del software registrado en Muisca.
DIAN_SOFTWARE_PIN=12345

# Ruta relativa al certificado digital .PFX.
# NUNCA incluir el archivo .pfx en el repositorio git.
DIAN_CERT_PATH=./certs/certificado.pfx

# Contrasena del archivo .PFX del certificado digital.
DIAN_CERT_PASSWORD=contrasena_segura_del_certificado
