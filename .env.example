# =============================================================================
# Variedades DANII — Secretos de Docker Compose (PLANTILLA)
# =============================================================================
# Copia este archivo como .env y completa con tus valores reales.
# NUNCA subas el .env real a Git.
# =============================================================================

# ── Base de datos ────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambiar_en_produccion
POSTGRES_DB=variedades_danni

# ── JWT ──────────────────────────────────────────────────────────────────────
# Genera uno con: openssl rand -base64 48
JWT_SECRET=genera-un-secreto-seguro-aqui

# ── Admin seed ───────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=CambiarEstaContraseña#
ADMIN_NAME=Administrador
ADMIN_PHONE=+573000000000

# ── Brevo SMTP ───────────────────────────────────────────────────────────────
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=tu_correo@ejemplo.com
EMAIL_PASS=tu_clave_smtp_brevo
EMAIL_FROM=tu_correo@ejemplo.com
EMAIL_FROM_NAME=Variedades DANII Perfumeria
