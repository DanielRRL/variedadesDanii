# ─────────────────────────────────────────────────────────────────────────────
# Variedades DANII — Frontend environment variables
# Copy this file to .env.local and fill in the values for your environment.
# NEVER commit .env.local or any file containing real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL — must NOT have a trailing slash.
# Docker Compose (internal):  http://backend:3000
# Local dev (outside Docker): http://localhost:3000
# Production:                 https://api.variedadesdanii.com
VITE_API_URL=http://localhost:3000
